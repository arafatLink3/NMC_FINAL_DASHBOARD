{
  "expo": {
    "name": "NMC Dashboard",
    "slug": "nmc-dashboard",
    "scheme": "nmc",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nmc.dashboard",
      "associatedDomains": ["applinks:nmc.example.com"]
    },
    "android": {
      "package": "com.nmc.dashboard",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [{ "scheme": "nmc", "host": "auth" }]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-linking",
        {
          "scheme": ["nmc"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "apiBaseUrl": "http://localhost:4099"
    }
  }
}