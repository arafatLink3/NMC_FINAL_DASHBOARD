# pnpm 11+ configuration for the NMC monorepo.
# The "pnpm" field in package.json is no longer read by pnpm 11+;
# settings must live here (see https://pnpm.io/settings).

# Allow these native packages to run their install/build scripts.
# pnpm 11 expects a single comma-separated list, NOT the npm-style key[]= syntax.
onlyBuiltDependencies=sqlite3,bcrypt,esbuild,protobufjs,better-sqlite3,node-gyp

# Skip the "do you trust these new deps?" gate on every command.
verifyDepsBeforeRun=false

# Be permissive about peer-deps; the legacy SPA fed in older majors.
strict-peer-dependencies=false
auto-install-peers=true