# --- Server runtime ---
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database ---
# SQLite (default) — path to a file. Use ":memory:" for ephemeral.
DB_CLIENT=sqlite
DB_FILENAME=./data/nmc.sqlite
# Postgres:
# DB_CLIENT=pg
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nmc
# DB_USER=nmc
# DB_PASSWORD=nmc

# --- Auth ---
# Override in production. Comma-separated allowed CORS origins.
CORS_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Telemetry (OpenTelemetry) ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=nmc-server
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14268/api/traces

# --- Uploads ---
UPLOAD_MAX_BYTES=26214400
